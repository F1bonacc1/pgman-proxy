# syntax=docker/dockerfile:1
# Production bundled image: pgman-proxy + PostgreSQL 18 in one container.
#
# Each peer in the active/active topology runs this image. pgman-proxy
# is PID 1; the wrapped pg-manager library drives initdb /
# pg_basebackup / pg_ctl against the local PGDATA at
# /var/lib/postgresql/data, so a separate "postgres" container is
# structurally wrong (see CLAUDE.md / specs/001-active-active-pg-proxy/).
#
# Distinct from `deploy/docker/Dockerfile`, which is a distroless static
# image holding only the pgman-proxy binary — appropriate for sidecar
# topologies where Postgres runs in a separate container or on the host.
#
# pgman-proxy/go.mod pins the wrapped pg-manager engine to a tagged release
# in a PRIVATE repo. The build stage fetches it with the Go toolchain,
# authenticating through a BuildKit *secret mount* (id=pgm_token). The token
# is read from a tmpfs mount and used to build a throwaway ~/.netrc that is
# created and deleted inside a single RUN, so the credential never lands in
# any image layer, build history, exported cache, or provenance attestation —
# even with `cache-to: mode=max` + `provenance: mode=max`. The matching CI
# workflow (.github/workflows/release-image.yml) supplies the secret via
# build-push-action's `secrets:` input; only `pgman-proxy/` is in the
# build context.

# --- stage 1: build pgman-proxy ---------------------------------------
# Go toolchain pinned to match pgman-proxy/go.mod's `go 1.26.3` line.
FROM golang:1.26.3-bookworm AS build
WORKDIR /src

COPY pgman-proxy /src/pgman-proxy
WORKDIR /src/pgman-proxy

# Fetch modules, including the private pinned pg-manager. The token is
# mounted as a tmpfs secret; the ~/.netrc holding it is written and removed
# within this single RUN, so it is absent from the committed layer (and thus
# from any exported cache or provenance). go.sum still pins the checksums.
ENV GOPRIVATE=github.com/f1bonacc1/* GOWORK=off
RUN --mount=type=secret,id=pgm_token \
    printf 'machine github.com login x-access-token password %s\n' \
        "$(cat /run/secrets/pgm_token)" > "$HOME/.netrc" \
    && chmod 600 "$HOME/.netrc" \
    && go mod download \
    && rm -f "$HOME/.netrc"

ARG VERSION=dev
ARG COMMIT=unknown
RUN CGO_ENABLED=0 go build \
        -trimpath \
        -ldflags="-s -w -X main.version=${VERSION} -X main.commit=${COMMIT}" \
        -o /out/pgman-proxy ./cmd/pgman-proxy

# --- stage 2: runtime — postgres:18-bookworm + pgman-proxy ------------
FROM postgres:18-bookworm

ARG VERSION=dev
ARG COMMIT=unknown
LABEL org.opencontainers.image.source="https://github.com/f1bonacc1/pgman-proxy"
LABEL org.opencontainers.image.licenses="Apache-2.0"
LABEL org.opencontainers.image.description="Active/active PostgreSQL HA proxy + lifecycle manager bundled with PostgreSQL 18"
LABEL org.opencontainers.image.version="${VERSION}"
LABEL org.opencontainers.image.revision="${COMMIT}"

COPY --from=build /out/pgman-proxy /usr/local/bin/pgman-proxy

# tini reaps the postgres process group when pgman-proxy exits, so a
# fast peer restart doesn't leave a dangling postmaster.
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
         tini \
         ca-certificates \
    && rm -rf /var/lib/apt/lists/*

ENV PGDATA=/var/lib/postgresql/data \
    PGMAN_PROXY_POSTGRES_DATA_DIR=/var/lib/postgresql/data \
    PGMAN_PROXY_POSTGRES_BIN_DIR=/usr/lib/postgresql/18/bin

# The postgres base image declares VOLUME /var/lib/postgresql/data and
# its default entrypoint expects an empty dir on first boot. We bypass
# that entrypoint, so we must guarantee an empty + correctly-owned
# PGDATA ourselves before dropping privileges.
RUN install -d -o postgres -g postgres -m 0700 "$PGDATA"

# FR-013: image runs unprivileged. Orchestrators that try `--user 0:0`
# are rejected by the operator's deployment layer.
USER postgres

# Data-plane (PostgreSQL wire), observability, control plane, embedded
# NATS client, and embedded NATS cluster routes (TCP only).
EXPOSE 6432 9090 9091 4222 6222

ENTRYPOINT ["/usr/bin/tini", "--", "/usr/local/bin/pgman-proxy"]
